module Lrama
  class Grammar
    class Rule
      def initialize: (
        ?id: untyped, ?lhs_token: untyped, ?rhs_tokens: untyped,
        ?lhs: untyped, ?rhs: untyped,
        ?token_code: untyped, ?nullable: untyped,
        ?precedence_sym: untyped, ?lineno: untyped
      ) -> void
    end
  end
end
